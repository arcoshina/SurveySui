{
  "name": "surveysui",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=24",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "dev": "pnpm --parallel -r dev",
    "move:build": "cd contracts && sui move build",
    "move:test": "cd contracts && sui move test --build-env testnet",
    "deploy:Devnet": "tsx scripts/src/init.ts",
    "certik:smoke:devnet": "tsx scripts/src/certik-smoke-devnet.ts",
    "admin:pool": "tsx scripts/src/admin-pool.ts"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.5",
    "prettier": "^3.5.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
