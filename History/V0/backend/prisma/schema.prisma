generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ParticipantSbtStatus {
  ACTIVE
  REVOKED
  SUPERSEDED
}

enum SurveyStatus {
  ACTIVE
  CLOSED
  EXPIRED
}

enum QuestionType {
  SINGLE_CHOICE
  MULTI_CHOICE
  SHORT_ANSWER
  SCALE
}

model User {
  id         String   @id @default(cuid())
  zkSubHash  String   @unique @map("zk_sub_hash")
  suiAddress String   @map("sui_address")
  createdAt  DateTime @default(now()) @map("created_at")

  sbts ParticipantSbt[]

  @@map("users")
}

model ParticipantSbt {
  id            String               @id @default(cuid())
  subHash       String               @map("sub_hash")
  serial        BigInt               @unique
  suiAddress    String               @map("sui_address")
  sbtObjectId   String               @unique @map("sbt_object_id")
  issuedAt      DateTime             @map("issued_at")
  expiresAt     DateTime             @map("expires_at")
  status        ParticipantSbtStatus
  supersedeOfId String?              @map("supersede_of")
  createdAt     DateTime             @default(now()) @map("created_at")

  user        User             @relation(fields: [subHash], references: [zkSubHash])
  supersedeOf ParticipantSbt?  @relation("SbtSupersession", fields: [supersedeOfId], references: [id])
  superseded  ParticipantSbt[] @relation("SbtSupersession")

  @@index([subHash])
  @@map("participant_sbts")
}

model Survey {
  id             String       @id @default(cuid())
  creatorAddress String       @map("creator_address")
  vaultObjectId  String       @unique @map("vault_object_id")
  contentMd      String       @map("content_md")
  contentHash    String       @map("content_hash")
  perResponse    BigInt       @map("per_response")
  maxResponses   Int          @map("max_responses")
  deadline       DateTime
  status         SurveyStatus
  createdAt      DateTime     @default(now()) @map("created_at")

  questions Question[]
  responses Response[]

  @@index([creatorAddress])
  @@map("surveys")
}

model Question {
  id          String       @id @default(cuid())
  surveyId    String       @map("survey_id")
  questionKey String       @map("question_key")
  order       Int
  type        QuestionType
  prompt      String
  optionsJson Json         @map("options_json")
  required    Boolean      @default(false)

  survey Survey @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@index([surveyId])
  @@map("questions")
}

model Response {
  id          String   @id @default(cuid())
  surveyId    String   @map("survey_id")
  subHash     String   @map("sub_hash")
  suiAddress  String   @map("sui_address")
  answersJson Json     @map("answers_json")
  contentHash String   @map("content_hash")
  claimedTx   String?  @map("claimed_tx")
  createdAt   DateTime @default(now()) @map("created_at")

  survey Survey @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@unique([surveyId, subHash])
  @@index([subHash])
  @@map("responses")
}
