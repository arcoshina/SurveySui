# =============================================================================
# SurveySui — 環境變數範本
# 複製此檔為 .env，填入實際值後即可本機開發
# =============================================================================

# Network
SUI_NETWORK=devnet
SUI_RPC_URL=https://fullnode.devnet.sui.io:443

# Sui Admin（部署合約 / 測試用）
# ed25519 hex，不含 0x 前綴；用 `sui keytool export` 取得
SUI_ADMIN_PRIVATE_KEY=
SUI_ADMIN_ADDRESS=

# Contract Object IDs（T1.7 deploy 後由 scripts 自動填入）
SUI_PACKAGE_ID=
SR_TREASURY_ID=
SSR_TREASURY_ID=
AMM_POOL_ID=
SURVEY_REGISTRY_ID=

# Dev test accounts（僅限 Devnet，不可持有真實資產）
# 12 字 BIP39 助記詞；用 pnpm tsx scripts/src/devAccounts.ts 衍生地址
DEV_MNEMONIC=

# SurveyPass Registry（deploy 後由 scripts 自動填入）
PASS_REGISTRY_ID=

# E2E 測試設定（S0.2）
# BFF 本機位址（預設 http://localhost:3100）
BFF_URL=http://localhost:3100
# 設為 1 以啟用需要真實 Devnet + BFF 的 e2e 測試
# 執行方式: E2E_ENABLED=1 pnpm -F frontend test e2e.v2
E2E_ENABLED=
