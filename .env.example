# =============================================================================
# SurveySui — 環境變數範本
# 複製此檔為 .env，填入實際值後即可本機開發
# =============================================================================

# Network
SUI_NETWORK=devnet
SUI_RPC_URL=https://fullnode.devnet.sui.io:443

# Sui Admin（部署合約 / 測試用）
# ed25519 hex，不含 0x 前綴；用 `sui keytool export` 取得
SUI_ADMIN_PRIVATE_KEY=
SUI_ADMIN_ADDRESS=

# Contract Object IDs（T1.7 deploy 後由 scripts 自動填入）
SUI_PACKAGE_ID=
SSR_TREASURY_ID=
SSSR_TREASURY_ID=
AMM_POOL_ID=
SURVEY_REGISTRY_ID=
