# =============================================================================
# SurveySui — 環境變數範本
# 複製此檔為 .env，填入實際值後即可本機開發
# =============================================================================

# Network
SUI_NETWORK=testnet
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# Sui Admin（部署合約 / 後端代簽 PTB 用）
# ed25519 hex，不含 0x 前綴；用 `sui keytool export` 取得
SUI_ADMIN_PRIVATE_KEY=
SUI_ADMIN_ADDRESS=

# Contract Object IDs（T1.7 deploy 後由 scripts/src/env-sync.ts 自動填入）
SUI_PACKAGE_ID=
RWD_TREASURY_CAP_ID=
AMM_POOL_ID=
SBT_REGISTRY_ID=

# Database（本機開發預設）
DATABASE_URL=postgresql://surveysui:dev_password@localhost:5432/surveysui_dev

# Google OAuth（zkLogin 用）
# 在 https://console.cloud.google.com/ 建立 OAuth 2.0 client
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# zkLogin ZK Prover（demo 用 Mysten Labs 公共節點）
ZKLOGIN_PROVER_URL=https://prover-dev.mystenlabs.com/v1
