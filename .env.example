# SurveySui 環境變數範本 — 複製為 .env 後填入實際值（.env 已被 git 忽略，勿提交真值）

# ── Sui 鏈設定 ────────────────────────────────────────────────────────────────
# 運作網路環境（例如 devnet, testnet, mainnet）
SUI_NETWORK=devnet
# Sui 節點 RPC 伺服器網址
SUI_RPC_URL=https://fullnode.devnet.sui.io:443
# 部署與治理用的管理員私鑰（請小心保護，不要流出，切勿放進 BFF runtime）
SUI_ADMIN_PRIVATE_KEY=REPLACE_ME
# 管理員錢包地址
SUI_ADMIN_ADDRESS=0x...
# 已部署的合約 Package ID
SUI_PACKAGE_ID=0x...
# SurveyRegistry 合約國庫 (Treasury) 物件 ID
SR_TREASURY_ID=0x...
# SurveySuiReward (SSR) 獎勵國庫物件 ID
SSR_TREASURY_ID=0x...
# 流動性池 (AMM Pool) 物件 ID，用於代幣兌換
AMM_POOL_ID=0x...
# SurveyRegistry 物件 ID (問卷系統主合約註冊表)
SURVEY_REGISTRY_ID=0x...
# PassRegistry 物件 ID (SurveyPass 註冊表)
PASS_REGISTRY_ID=0x...
# IssuerConfig 物件 ID (憑證簽發者合約設定)
ISSUER_CONFIG_ID=0x...

# ── 資料庫設定 ────────────────────────────────────────────────────────────────
# PostgreSQL 資料庫連線網址
DATABASE_URL=postgresql://surveysui:REPLACE_ME@127.0.0.1:5432/surveysui_dev

# ── OAuth / Email 身分驗證設定 ────────────────────────────────────────────────
# Google OAuth 登入用戶端識別碼 (Client ID)
GOOGLE_OAUTH_CLIENT_ID=REPLACE_ME
# Google OAuth 登入用戶端金鑰 (Client Secret)
GOOGLE_OAUTH_CLIENT_SECRET=REPLACE_ME
# GitHub OAuth 登入用戶端識別碼 (Client ID)
GITHUB_OAUTH_CLIENT_ID=REPLACE_ME
# GitHub OAuth 登入用戶端金鑰 (Client Secret)
GITHUB_OAUTH_CLIENT_SECRET=REPLACE_ME
# Resend 郵件傳送服務的 API 金鑰
RESEND_API_KEY=REPLACE_ME
# 系統發信所使用的寄件者電子郵件地址
EMAIL_FROM=noreply@surveysui.com
# Mysten Labs 的 zkLogin Prover 證明產生服務網址
ZKLOGIN_PROVER_URL=https://prover-dev.mystenlabs.com/v1
# BFF 後端 Admin API 的訪問保護密鑰 (Admin Secret)
ADMIN_SECRET=REPLACE_ME
# 開發測試用助記詞 (用於測試帳戶或 Gas 贊助錢包初始化)
DEV_MNEMONIC=REPLACE_ME

# ── SurveyPass 簽發者 (BFF) ───────────────────────────────────────────────────
# Ed25519 憑證 ticket 簽章私鑰（32位元組十六進制）
SURVEY_PASS_ISSUER_PRIV=REPLACE_ME
# 用於計算 nullifier 隱私的高熵鹽值 (Nullifier Pepper / Salt)
# 用於保護用戶電子郵件等低熵資訊不被暴力破解
# getIssuerSalt() 會在缺值/空字串/字面值 "default_salt"/長度 < 12 時直接丟錯。
# 產生範例：openssl rand -hex 32
SURVEY_PASS_ISSUER_SALT=REPLACE_ME_WITH_HIGH_ENTROPY_SECRET

# ── World ID 驗證設定 ─────────────────────────────────────────────────────────
# Worldcoin 應用程式識別碼 (Developer Portal 中的 App ID)
WORLDCOIN_APP_ID=REPLACE_ME
# Worldcoin 憑證者識別碼 (Relying Party ID)
WORLDCOIN_RP_ID=REPLACE_ME
# World ID 用於後端驗證的簽章金鑰 (Signing Key，絕不離開後端)
WORLDCOIN_SIGNING_KEY=REPLACE_ME
# Worldcoin 用戶驗證的行為名稱 (Action)
WORLDCOIN_ACTION=surveysui-worldcoin-verifier

# ── 系統一般設定 ──────────────────────────────────────────────────────────────
# 前端網頁的執行與存取網址（BFF 用於跨來源 CORS 檢查等）
FRONTEND_URL=http://localhost:5173
# 應用程式環境（development / production）
NODE_ENV=development
# BFF 後端補償/贊助 Gas 的最小金額門檻 (以 MIST 為單位，例如 15,000,000 MIST = 0.015 SUI)
MIN_GAS_COMPENSATION_AMOUNT=15_000_000
# BFF 後端收取的 Premium 服務費 (以 MIST 為單位，10^6 MIST = 0.001 SUI)
BFF_PREMIUM_FEE_MIST=1000000

# ── 前端 (Vite，於 build 時靜態注入) ──────────────────────────────────────────
# 前端用來與 BFF 後端連線的 API 網址
VITE_BFF_URL=http://localhost:3100
# 前端設定的 Premium 服務費顯示值 (以 MIST 為單位，需與 BFF_PREMIUM_FEE_MIST 保持一致)
VITE_PREMIUM_FEE_MIST=1000000
# 前端 World ID 驗證元件所屬環境 (staging / production)
VITE_WORLDCOIN_ENV=staging
# 前端限制單個問卷資料大小上限 (KB)
VITE_SURVEY_SIZE_THRESHOLD_KB=10
# 前端限制單個問卷答案資料大小上限 (KB)
VITE_ANSWER_SIZE_THRESHOLD_KB=4
# Walrus 去中心化存儲的上傳服務網址 (Publisher)
VITE_WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
# Walrus 去中心化存儲的下載服務網址 (Aggregator)
VITE_WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space

# ── Pass 憑證效期 TTL（毫秒）覆寫；留空則用程式碼預設（bff/src/auth/ticket.ts）──
# 預設值：Email 3 個月、社群(含 Google/GitHub) 3 個月、World ID 1 年。
# 只在需要臨時修改參數時啟用：
# Email 驗證碼登入發送憑證的 TTL (例如 90天 = 7776000000 毫秒)
# BFF_PASS_TTL_MS_EMAIL=7776000000
# Google/GitHub 社群登入發送憑證的 TTL (例如 90天 = 7776000000 毫秒)
# BFF_PASS_TTL_MS_SOCIAL=7776000000
# World ID 驗證登入發送憑證的 TTL (例如 365天 = 31536000000 毫秒)
# BFF_PASS_TTL_MS_WORLDID=31536000000
# 全域 fallback 效期（未分來源時）
# BFF_PASS_TTL_MS=

# ── BFF 背景定時清理任務 ──────────────────────────────────────────────────────
# 是否啟用自動銷毀過期問卷/憑證的 BFF 定時任務 (true/false)
PURGE_TASK_ENABLED=true
# 銷毀任務的掃描間隔時間（毫秒），例如 86400000 毫秒 = 24 小時
PURGE_SCAN_INTERVAL_MS=86400000
# 每輪掃描最多銷毀的問卷數量上限（避免單次負載過高，預設為 10）
# PURGE_MAX_PER_CYCLE=10
