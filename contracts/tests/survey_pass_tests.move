#[test, expected_failure(abort_code = surveysui::survey_pass::EOwnerMismatch)]
fun test_surveypass_mint_rejects_wrong_owner() {
    let mut sc = setup();
    let clk = clock::create_for_testing(sc.ctx());

    sc.next_tx(BOB); // Bob tries to use Alice's ticket
    {
        let mut registry = ts::take_shared<NullifierRegistry>(&sc);
        let config = ts::take_shared<IssuerConfig>(&sc);
        survey_pass::mint_pass(
            &mut registry,
            &config,
            ALICE, // Alice is the owner
            2,
            alice_nullifier(),
            vector[],
            EXPIRES_AT,
            alice_valid_sig(), // Alice's sig
            &clk,
            sc.ctx()
        ); // aborts EOwnerMismatch because sender is BOB, but owner is ALICE
        ts::return_shared(config);
        ts::return_shared(registry);
    };

    clock::destroy_for_testing(clk);
    sc.end();
}

