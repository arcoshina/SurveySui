#[test]
fun test_surveypass_revoke_sets_revoked_status() {
    let mut sc = setup();
    let mut clk = clock::create_for_testing(sc.ctx());
    clock::set_for_testing(&mut clk, T0);

    sc.next_tx(ALICE);
    {
        let mut registry = ts::take_shared<NullifierRegistry>(&sc);
        let config = ts::take_shared<IssuerConfig>(&sc);
        survey_pass::mint_pass(
            &mut registry,
            &config,
            ALICE,
            2,
            alice_nullifier(),
            vector[],
            EXPIRES_AT,
            alice_valid_sig(),
            &clk,
            sc.ctx()
        );
        ts::return_shared(config);
        ts::return_shared(registry);
    };

    sc.next_tx(ADMIN);
    {
        let config = ts::take_shared<IssuerConfig>(&sc);
        let mut pass = ts::take_shared<SurveyPass>(&sc);
        survey_pass::revoke_pass(&mut pass, &config, sc.ctx());
        assert!(survey_pass::status(&pass) == 3, 30); // STATUS_REVOKED
        assert!(!survey_pass::is_valid(&pass, &clk), 31);
        ts::return_shared(pass);
        ts::return_shared(config);
    };

    clock::destroy_for_testing(clk);
    sc.end();
}

#[test]
fun test_surveypass_delete_after_revoke() {
    let mut sc = setup();
    let mut clk = clock::create_for_testing(sc.ctx());
    clock::set_for_testing(&mut clk, T0);

    sc.next_tx(ALICE);
    {
        let mut registry = ts::take_shared<NullifierRegistry>(&sc);
        let config = ts::take_shared<IssuerConfig>(&sc);
        survey_pass::mint_pass(
            &mut registry,
            &config,
            ALICE,
            2,
            alice_nullifier(),
            vector[],
            EXPIRES_AT,
            alice_valid_sig(),
            &clk,
            sc.ctx()
        );
        ts::return_shared(config);
        ts::return_shared(registry);
    };

    sc.next_tx(ADMIN);
    {
        let config = ts::take_shared<IssuerConfig>(&sc);
        let mut pass = ts::take_shared<SurveyPass>(&sc);
        survey_pass::revoke_pass(&mut pass, &config, sc.ctx());
        ts::return_shared(pass);
        ts::return_shared(config);
    };

    sc.next_tx(ALICE);
    {
        let pass = ts::take_shared<SurveyPass>(&sc);
        survey_pass::delete_pass(pass, sc.ctx());
    };

    clock::destroy_for_testing(clk);
    sc.end();
}
