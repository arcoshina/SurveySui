const T0: u64 = 1_000_000_000;
const EXPIRES_AT: u64 = 99999999999999;

fun setup(): ts::Scenario {
    let mut sc = ts::begin(ADMIN);
    survey_pass::test_init(sc.ctx());
    sc.next_tx(ADMIN);
    {
        let mut config = ts::take_shared<IssuerConfig>(&sc);
        survey_pass::set_issuer_pubkey(&mut config, bff_pubkey(), sc.ctx());
        ts::return_shared(config);
    };
    sc.next_tx(ADMIN);
    sc
}

#[test]
fun test_surveypass_mint_happy_path() {
    let mut sc = setup();
    let mut clk = clock::create_for_testing(sc.ctx());
    clock::set_for_testing(&mut clk, T0);

    // Alice mints pass
    sc.next_tx(ALICE);
    {
        let mut registry = ts::take_shared<NullifierRegistry>(&sc);
        let config = ts::take_shared<IssuerConfig>(&sc);
        survey_pass::mint_pass(
            &mut registry,
            &config,
            ALICE,
            2, // SRC_EMAIL
            alice_nullifier(),
            vector[],
            EXPIRES_AT,
            alice_valid_sig(),
            &clk,
            sc.ctx()
        );
        ts::return_shared(config);
        ts::return_shared(registry);
    };

    sc.next_tx(ALICE);
    {
        let pass = ts::take_shared<SurveyPass>(&sc);
        assert!(survey_pass::owner(&pass) == ALICE, 1);
        assert!(survey_pass::status(&pass) == 0, 2); // STATUS_ACTIVE
        assert!(survey_pass::effective_tier(&pass) == 0, 3); // Email OTP tier is 0
        assert!(survey_pass::expires_at(&pass) == EXPIRES_AT, 4);
        assert!(survey_pass::is_valid(&pass, &clk), 5);
        ts::return_shared(pass);
    };

    clock::destroy_for_testing(clk);
    sc.end();
}

#[test, expected_failure(abort_code = surveysui::survey_pass::EDuplicateNullifier)]
fun test_surveypass_mint_rejects_duplicate_nullifier() {
    let mut sc = setup();
    let clk = clock::create_for_testing(sc.ctx());

    // Alice mints pass
    sc.next_tx(ALICE);
    {
        let mut registry = ts::take_shared<NullifierRegistry>(&sc);
        let config = ts::take_shared<IssuerConfig>(&sc);
        survey_pass::mint_pass(
            &mut registry,
            &config,
            ALICE,
            2,
            alice_nullifier(),
            vector[],
            EXPIRES_AT,
            alice_valid_sig(),
            &clk,
            sc.ctx()
        );
        ts::return_shared(config);
        ts::return_shared(registry);
    };

    // Bob tries to mint using Alice's nullifier (duplicate)
    sc.next_tx(BOB);
    {
        let mut registry = ts::take_shared<NullifierRegistry>(&sc);
        let config = ts::take_shared<IssuerConfig>(&sc);
        survey_pass::mint_pass(
            &mut registry,
            &config,
            BOB,
            2,
            alice_nullifier(),
            vector[],
            EXPIRES_AT,
            bob_malicious_sig(),
            &clk,
            sc.ctx()
        ); // must abort EDuplicateNullifier because Alice already registered it
        ts::return_shared(config);
        ts::return_shared(registry);
    };

    clock::destroy_for_testing(clk);
    sc.end();
}

#[test]
fun test_surveypass_mint_allows_update_same_owner() {
    let mut sc = setup();
    let mut clk = clock::create_for_testing(sc.ctx());
    clock::set_for_testing(&mut clk, T0);

    // Alice mints pass
    sc.next_tx(ALICE);
    {
        let mut registry = ts::take_shared<NullifierRegistry>(&sc);
        let config = ts::take_shared<IssuerConfig>(&sc);
        survey_pass::mint_pass(
            &mut registry,
            &config,
            ALICE,
            2,
            alice_nullifier(),
            vector[],
            EXPIRES_AT,
            alice_valid_sig(),
            &clk,
            sc.ctx()
        );
        ts::return_shared(config);
        ts::return_shared(registry);
    };

    // Alice updates same credential (e.g. renewal)
    sc.next_tx(ALICE);
    {
        let mut pass = ts::take_shared<SurveyPass>(&sc);
        let mut registry = ts::take_shared<NullifierRegistry>(&sc);
        let config = ts::take_shared<IssuerConfig>(&sc);
        // Alice renews with a ticket having expires_at + 1000
        survey_pass::update_pass_credential(
            &mut pass,
            &mut registry,
            &config,
            2,
            alice_nullifier(),
            vector[],
            EXPIRES_AT, // same expires_at is fine, or we can use the same valid sig
            alice_valid_sig(),
            &clk,
            sc.ctx()
        );
        ts::return_shared(config);
        ts::return_shared(registry);
        ts::return_shared(pass);
    };

    clock::destroy_for_testing(clk);
    sc.end();
}

#[test, expected_failure(abort_code = surveysui::survey_pass::EInvalidTicketSig)]
